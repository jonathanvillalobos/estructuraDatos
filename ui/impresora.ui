   </rect>
  </property>
  <property name="windowTitle">
   <string>Simulador de Cola de Impresión FIFO</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Fondo del Diálogo - Negro Puro */
    QDialog {
        background-color: #0F0F0F;
    }
    
    /* Tarjetas contenedoras - Gris Oscuro */
    QGroupBox {
        background-color: #1A1A1A;
        border: 1px solid #2B2B2B;
        border-radius: 8px;
        margin-top: 15px;
        font-size: 13px;
        font-weight: bold;
        color: #A0A0A0;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        left: 15px;
        padding: 0 5px;
    }

    /* Textos generales */
    QLabel {
        color: #D3D3D3;
        font-size: 12px;
    }
    
    /* Etiquetas de estado */
    QLabel#lbl_total_pendientes {
        font-size: 13px;
        color: #888888;
    }
    QLabel#lbl_siguiente {
        font-size: 13px;
        font-weight: bold;
        color: #388E3C;
        background-color: #122214;
        padding: 8px;
        border-radius: 5px;
        border: 1px dashed #2E5C32;
    }

    /* Campos de entrada - Gris más claro */
    QLineEdit, QSpinBox {
        background-color: #2D2D2D;
        border: 1px solid #3D3D3D;
        border-radius: 5px;
        color: #FFFFFF;
        padding: 6px 10px;
        font-size: 12px;
    }
    QLineEdit:focus, QSpinBox:focus {
        border: 1px solid #0084FF;
    }

    /* Lista de Consulta */
    QListWidget {
        background-color: #1A1A1A;
        border: 1px solid #2B2B2B;
        border-radius: 8px;
        color: #E0E0E0;
        padding: 10px;
        font-size: 13px;
    }
    QListWidget::item {
        background-color: #242424;
        border: 1px solid #2F2F2F;
        border-radius: 5px;
        padding: 8px;
        margin-bottom: 6px;
    }

    /* Botones */
    QPushButton {
        background-color: #2D2D2D;
        border: 1px solid #444444;
        color: #FFFFFF;
        border-radius: 5px;
        padding: 8px;
        font-weight: bold;
        font-size: 12px;
    }
    QPushButton:hover {
        background-color: #3A3A3A;
        border-color: #555555;
    }
    QPushButton:pressed {
        background-color: #242424;
    }

    /* Botón de Acción Especial (Imprimir) */
    QPushButton#btn_imprimir {
        background-color: #0066CC;
        border: 1px solid #0052A3;
    }
    QPushButton#btn_imprimir:hover {
        background-color: #0080FF;
    }
   </string>
  </property>
