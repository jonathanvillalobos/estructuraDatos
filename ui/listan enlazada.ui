  <property name="styleSheet">
   <string notr="true">/* ==========================================================================
   1. LINE EDIT (QLineEdit)
   ========================================================================== */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 10px;
    color: #1f2937;
    font-size: 13px;
    selection-background-color: #3b82f6; /* Color al seleccionar texto */
}

/* Cuando el usuario hace clic para escribir */
QLineEdit:focus {
    border: 2px solid #3b82f6;
    background-color: #ffffff;
}

/* Estado cuando el campo está deshabilitado */
QLineEdit:disabled {
    background-color: #f3f4f6;
    color: #9ca3af;
    border: 1px solid #e5e7eb;
}

/* ==========================================================================
   2. PUSH BUTTON (QPushButton)
   ========================================================================== */
QPushButton {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: bold;
}

/* Al pasar el cursor por encima */
QPushButton:hover {
    background-color: #2563eb;
}

/* Al hacer clic */
QPushButton:pressed {
    background-color: #1d4ed8;
    padding-left: 18px; /* Sutil efecto de hundimiento */
    padding-top: 9px;
}

/* Estado deshabilitado */
QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}

/* ==========================================================================
   3. MENU BAR Y MENÚS DESPLEGABLES (QMenuBar y QMenu)
   ========================================================================== */
/* La barra horizontal superior */
QMenuBar {
    background-color: #f3f4f6;
    border-bottom: 1px solid #d1d5db;
    color: #1f2937;
    font-size: 13px;
}

/* Los elementos de la barra superior (Archivo, Editar, etc.) */
QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #e5e7eb;
    color: #000000;
}

/* El menú que se despliega hacia abajo */
QMenu {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    padding: 5px 0px;
}

/* Las opciones dentro del menú desplegable */
QMenu::item {
    padding: 6px 25px 6px 20px;
    color: #1f2937;
}

/* Al pasar el cursor sobre una opción del menú desplegable */
QMenu::item:selected {
    background-color: #3b82f6;
    color: #ffffff;
}</string>
