  <property name="styleSheet">
   <string notr="true">/* --- ESTILO GENERAL DE LA VENTANA (Opcional, por si quieres fondo claro) --- */
QWidget {
    background-color: #FAFAFA;
}

/* --- LINE EDIT (Caja de texto) --- */
/* Se ve amigable, con un borde morado pastel que se ilumina al hacer clic */
QLineEdit {
    background-color: #FFFFFF;
    border: 3px solid #B39DDB; /* Morado pastel */
    border-radius: 12px;       /* Bordes muy redondeados/asimétricos estilo aesthetic */
    padding: 6px 12px;
    color: #2C3E50;
}

QLineEdit:focus {
    border: 3px solid #FF80AB; /* Cambia a rosa chicle cuando escribes */
    background-color: #FFF9FA;
}

/* --- PUSH BUTTON (Botón) --- */
/* Un estilo tipo &quot;gominola&quot; o sticker: amarillo/naranja vibrante que reacciona al pasar el mouse */
QPushButton {
    background-color: #FFCA28; /* Amarillo huevo/vibrante */
    border: 2px solid #F57C00; /* Borde naranja para darle profundidad */
    border-radius: 15px;       /* Súper redondeado */
    color: #37474F;            /* Texto oscuro para que contraste chido */
    padding: 8px 16px;
    font-weight: bold;         /* Para que resalte el texto */
}

QPushButton:hover {
    background-color: #FFE082; /* Se aclara cuando pasas el cursor */
}

QPushButton:pressed {
    background-color: #FFB300; /* Se oscurece un poco al darle clic (efecto de hundido) */
    border: 2px solid #E65100;
    padding-top: 10px;         /* Truco visual: simula que se hunde */
    padding-bottom: 6px;
}

/* --- QLabel (Etiquetas de texto) --- */
/* Un toque de color aqua/turquesa para los textos */
QLabel {
    color: #00ACC1;            /* Azul turquesa juguetón */
    background-color: transparent;
}</string>
