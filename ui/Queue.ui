  <property name="styleSheet">
   <string notr="true">/* ==========================================================================
   VENTANA PRINCIPAL
   ========================================================================== */
QMainWindow, QWidget {
    background-color: #0c0c0c;
}

/* ==========================================================================
   BOTONES (QPushButton) - TAMAÑO ULTRA MINI
   ========================================================================== */
QPushButton {
    background-color: #141414;
    color: #aaaaaa;
    border: 1px solid #222222;
    border-radius: 3px;
    font-family: "Arial Narrow", "Segoe UI Condensed", sans-serif;
    font-size: 7px; 
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    padding: 0px;
    margin: 0px;
}

QPushButton:hover {
    background-color: #1a1a1a;
    color: #ffffff;
    border: 1px solid #a38a6b; 
}

QPushButton:pressed {
    background-color: #080808;
    border: 1px solid #73614c;
    color: #777777;
}

QPushButton:disabled {
    background-color: #0e0e0e;
    color: #333333;
    border: 1px solid #151515;
}

/* ==========================================================================
   CAJA DE TEXTO (QLineEdit) - ESTILO BLACK COHERENTE
   ========================================================================== */
QLineEdit {
    background-color: #141414;
    color: #ffffff;
    border: 1px solid #222222;
    border-radius: 3px;
    padding: 2px 6px;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 10px;
}

QLineEdit:focus {
    border: 1px solid #a38a6b;
    background-color: #1a1a1a;
}

/* ==========================================================================
   ETIQUETAS DE TEXTO (QLabel) - MÁS GRANDES
   ========================================================================== */
QLabel {
    color: #d4af37;
    background-color: transparent;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 11px; 
    font-weight: 600;
    padding: 0px;
}</string>
