  <property name="styleSheet">
   <string notr="true">/* --- CONFIGURACIÓN GENERAL --- */
QWidget {
    background-color: #1e1e24;
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;, sans-serif;
}

/* --- QLABEL (Etiquetas) --- */
QLabel {
    background-color: transparent;
    color: #ffffff;
    font-weight: 500;
}

/* --- QLINEEDIT (Campos de texto) --- */
QLineEdit {
    background-color: #33333c;
    color: #ffffff;
    border: 1px solid #4a4a54;
    border-radius: 5px;
    padding: 5px 8px;
}

QLineEdit:focus {
    border: 1px solid #007acc;
    background-color: #3a3a46;
}

/* --- QPUSHBUTTON (Botones) --- */
QPushButton {
    background-color: #3a3a45;
    color: #ffffff;
    border: 1px solid #4f4f5d;
    border-radius: 5px;
    padding: 6px 12px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #4a4a57;
    border: 1px solid #007acc;
}

QPushButton:pressed {
    background-color: #23232a;
    border: 1px solid #005999;
}

QPushButton:disabled {
    background-color: #2a2a32;
    color: #666666;
    border: 1px solid #3a3a42;
}

/* --- QLISTWIDGET (Listas) --- */
QListWidget {
    background-color: #33333c;
    border: 1px solid #4a4a54;
    border-radius: 6px;
    padding: 5px;
}

QListWidget::item {
    padding: 8px;
    border-radius: 4px;
    color: #e0e0e0;
}

QListWidget::item:hover {
    background-color: #40404c;
    color: #ffffff;
}

QListWidget::item:selected {
    background-color: #007acc;
    color: #ffffff;
}

/* Ajuste para la barra de desplazamiento */
QScrollBar:vertical {
    background: #1e1e24;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #4f4f5d;
    min-height: 20px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #007acc;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
    height: 0px;
}</string>
