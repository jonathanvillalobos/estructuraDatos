  <property name="styleSheet">
   <string notr="true">/* ==========================================================================
   1. LINE EDIT (QLineEdit)
   ========================================================================== */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 10px;
    color: #1f2937;
    font-size: 13px;
    selection-background-color: #3b82f6;
}

QLineEdit:focus {
    border: 2px solid #3b82f6;
    background-color: #ffffff;
}

QLineEdit:disabled {
    background-color: #f3f4f6;
    color: #9ca3af;
    border: 1px solid #e5e7eb;
}

/* ==========================================================================
   2. PUSH BUTTON (QPushButton)
   ========================================================================== */
QPushButton {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2563eb;
}

QPushButton:pressed {
    background-color: #1d4ed8;
    padding-left: 18px;
    padding-top: 9px;
}

QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}

/* ==========================================================================
   3. MENU BAR Y MENÚS DESPLEGABLES (QMenuBar y QMenu)
   ========================================================================== */
QMenuBar {
    background-color: #f3f4f6;
    border-bottom: 1px solid #d1d5db;
    color: #1f2937;
    font-size: 13px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #e5e7eb;
    color: #000000;
}

QMenu {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    padding: 5px 0px;
}

QMenu::item {
    padding: 6px 25px 6px 20px;
    color: #1f2937;
}

QMenu::item:selected {
    background-color: #3b82f6;
    color: #ffffff;
}</string>
  </property>
